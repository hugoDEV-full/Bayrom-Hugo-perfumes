# Configurações do Servidor
NODE_ENV=development
PORT=3000
SESSION_SECRET=bayrom-hugo-perfumes-secret-2024-change-this-in-production

# Configurações do Banco de Dados
# Para Railway: Use DATABASE_URL (mysql://user:password@host:port/database)
# Para desenvolvimento local: Use as variáveis separadas abaixo
DATABASE_URL=mysql://user:password@localhost:3306/bayrom_hugo_perfumes
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bayrom_hugo_perfumes
DB_USER=root
DB_PASSWORD=

# Configurações de Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu-email@gmail.com
EMAIL_PASS=sua-senha-de-app
EMAIL_FROM=Bayrom & Hugo Parfums <contato@bayromhugoperfumes.com.br>

# Configurações de Pagamento
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
MERCADO_PAGO_PUBLIC_KEY=TEST-your-mercado-pago-public-key
MERCADO_PAGO_ACCESS_TOKEN=TEST-your-mercado-pago-access-token

# Configurações dos Correios
CORREIOS_TOKEN=seu-token-dos-correios
CORREIOS_CARTAO_POSTAGEM=seu-cartao-postagem

# URLs do Sistema
# Para Railway: Será definida automaticamente pela variável RAILWAY_URL
BASE_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Configurações de Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,webp

# Configurações de Rate Limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
