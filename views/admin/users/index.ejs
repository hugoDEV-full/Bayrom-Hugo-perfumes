<%- include('../../partials/header') %>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0">Usuários</h1>
            <div class="text-muted small">Clientes cadastrados</div>
        </div>
        <a href="/admin" class="btn btn-outline-secondary">Voltar</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nome</th>
                            <th>Email</th>
                            <th>Status</th>
                            <th class="text-end">Criado</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (!users || users.length === 0) { %>
                            <tr><td colspan="5" class="text-muted">Nenhum usuário.</td></tr>
                        <% } else { %>
                            <% users.forEach(u => { %>
                                <tr>
                                    <td><%= u.id %></td>
                                    <td><%= u.name %></td>
                                    <td><%= u.email %></td>
                                    <td><span class="badge bg-light text-dark"><%= u.status %></span></td>
                                    <td class="text-end"><%= u.createdAt ? new Date(u.createdAt).toLocaleDateString('pt-BR') : '' %></td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<%- include('../../partials/footer') %>
