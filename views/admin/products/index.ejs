<%- include('../../partials/header') %>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0">Produtos</h1>
            <div class="text-muted small">Gerencie o catálogo para vender mais</div>
        </div>
        <div class="d-flex gap-2">
            <a href="/admin" class="btn btn-outline-secondary">Voltar</a>
            <a href="/admin/products/new" class="btn btn-primary">Novo produto</a>
        </div>
    </div>

    <form method="GET" action="/admin/products" class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Busca</label>
                    <input name="search" value="<%= filters?.search || '' %>" class="form-control" placeholder="Nome, SKU, marca" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Categoria</label>
                    <select name="category" class="form-select">
                        <option value="">Todas</option>
                        <% if (categories && categories.length) { %>
                            <% categories.forEach(c => { %>
                                <option value="<%= c.slug %>" <%= (filters?.category === c.slug) ? 'selected' : '' %>><%= c.name %></option>
                            <% }) %>
                        <% } %>
                        <option value="masculino" <%= (filters?.category === 'masculino') ? 'selected' : '' %>>Masculino</option>
                        <option value="feminino" <%= (filters?.category === 'feminino') ? 'selected' : '' %>>Feminino</option>
                        <option value="unisex" <%= (filters?.category === 'unisex') ? 'selected' : '' %>>Unisex</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Status</label>
                    <select name="status" class="form-select">
                        <option value="">Todos</option>
                        <option value="active" <%= (filters?.status === 'active') ? 'selected' : '' %>>Ativo</option>
                        <option value="inactive" <%= (filters?.status === 'inactive') ? 'selected' : '' %>>Inativo</option>
                        <option value="draft" <%= (filters?.status === 'draft') ? 'selected' : '' %>>Rascunho</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button class="btn btn-outline-primary w-100" type="submit">Filtrar</button>
                    <a class="btn btn-outline-secondary" href="/admin/products">Limpar</a>
                </div>
            </div>
        </div>
    </form>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Produto</th>
                            <th>SKU</th>
                            <th>Categoria</th>
                            <th class="text-end">Preço</th>
                            <th class="text-end">Estoque</th>
                            <th>Status</th>
                            <th class="text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (!products || products.length === 0) { %>
                            <tr>
                                <td colspan="8" class="text-muted">Nenhum produto encontrado.</td>
                            </tr>
                        <% } else { %>
                            <% products.forEach(p => { %>
                                <tr>
                                    <td><%= p.id %></td>
                                    <td>
                                        <div class="fw-semibold"><%= p.name %></div>
                                        <div class="text-muted small"><%= p.brand %></div>
                                    </td>
                                    <td><%= p.sku %></td>
                                    <td><%= p.category %></td>
                                    <td class="text-end">R$ <%= Number(p.sale_price || p.regular_price || 0).toFixed(2) %></td>
                                    <td class="text-end"><%= p.stock_quantity ?? 0 %></td>
                                    <td>
                                        <% if (p.status === 'active') { %>
                                            <span class="badge bg-success">ativo</span>
                                        <% } else if (p.status === 'inactive') { %>
                                            <span class="badge bg-secondary">inativo</span>
                                        <% } else { %>
                                            <span class="badge bg-warning text-dark">rascunho</span>
                                        <% } %>
                                    </td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <a class="btn btn-sm btn-outline-primary" href="/products/<%= p.slug %>" target="_blank">Ver</a>
                                            <a class="btn btn-sm btn-primary" href="/admin/products/<%= p.id %>/edit">Editar</a>
                                            <% if (p.status === 'active') { %>
                                                <form method="POST" action="/admin/products/<%= p.id %>/deactivate" class="d-inline">
                                                    <button class="btn btn-sm btn-outline-danger" type="submit">Desativar</button>
                                                </form>
                                            <% } else { %>
                                                <form method="POST" action="/admin/products/<%= p.id %>/activate" class="d-inline">
                                                    <button class="btn btn-sm btn-outline-success" type="submit">Ativar</button>
                                                </form>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <% if (pagination && pagination.totalPages > 1) { %>
                <nav>
                    <ul class="pagination justify-content-end mb-0">
                        <li class="page-item <%= pagination.hasPrevPage ? '' : 'disabled' %>">
                            <a class="page-link" href="?page=<%= pagination.currentPage - 1 %>">Anterior</a>
                        </li>
                        <li class="page-item disabled"><span class="page-link">Página <%= pagination.currentPage %> / <%= pagination.totalPages %></span></li>
                        <li class="page-item <%= pagination.hasNextPage ? '' : 'disabled' %>">
                            <a class="page-link" href="?page=<%= pagination.currentPage + 1 %>">Próxima</a>
                        </li>
                    </ul>
                </nav>
            <% } %>
        </div>
    </div>
</div>

<%- include('../../partials/footer') %>
