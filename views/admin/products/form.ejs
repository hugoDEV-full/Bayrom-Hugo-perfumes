<%- include('../../partials/header') %>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0"><%= action === 'edit' ? 'Editar produto' : 'Novo produto' %></h1>
            <div class="text-muted small">Campos essenciais para vender (e os avançados para escalar)</div>
        </div>
        <div class="d-flex gap-2">
            <a href="/admin/products" class="btn btn-outline-secondary">Voltar</a>
        </div>
    </div>

    <form method="POST" action="<%= action === 'edit' ? '/admin/products/' + product.id : '/admin/products' %>" class="card shadow-sm">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Nome *</label>
                    <input name="name" class="form-control" value="<%= product.name || '' %>" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">SKU *</label>
                    <input name="sku" class="form-control" value="<%= product.sku || '' %>" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Marca *</label>
                    <input name="brand" class="form-control" value="<%= product.brand || '' %>" required />
                </div>

                <div class="col-md-4">
                    <label class="form-label">Categoria *</label>
                    <select name="category" class="form-select" required>
                        <option value="">Selecione</option>
                        <option value="masculino" <%= product.category === 'masculino' ? 'selected' : '' %>>Masculino</option>
                        <option value="feminino" <%= product.category === 'feminino' ? 'selected' : '' %>>Feminino</option>
                        <option value="unisex" <%= product.category === 'unisex' ? 'selected' : '' %>>Unisex</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Tamanho (ml) *</label>
                    <input name="size_ml" type="number" class="form-control" value="<%= (product.size_ml ?? '') %>" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Família olfativa</label>
                    <input name="fragrance_family" class="form-control" value="<%= product.fragrance_family || '' %>" placeholder="ex: floral" />
                </div>

                <div class="col-md-4">
                    <label class="form-label">Preço normal (R$) *</label>
                    <input name="regular_price" type="number" step="0.01" class="form-control" value="<%= (product.regular_price ?? '') %>" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Preço promocional (R$)</label>
                    <input name="sale_price" type="number" step="0.01" class="form-control" value="<%= (product.sale_price ?? '') %>" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Custo (R$)</label>
                    <input name="cost_price" type="number" step="0.01" class="form-control" value="<%= (product.cost_price ?? '') %>" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Estoque *</label>
                    <input name="stock_quantity" type="number" class="form-control" value="<%= (product.stock_quantity ?? 0) %>" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Estoque mínimo</label>
                    <input name="min_stock" type="number" class="form-control" value="<%= (product.min_stock ?? 5) %>" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Status</label>
                    <select name="status" class="form-select">
                        <option value="active" <%= product.status === 'active' ? 'selected' : '' %>>Ativo</option>
                        <option value="inactive" <%= product.status === 'inactive' ? 'selected' : '' %>>Inativo</option>
                        <option value="draft" <%= product.status === 'draft' ? 'selected' : '' %>>Rascunho</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Destaque</label>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="is_featured" <%= product.is_featured ? 'checked' : '' %> />
                        <label class="form-check-label">Mostrar na Home</label>
                    </div>
                </div>

                <div class="col-12">
                    <label class="form-label">Descrição</label>
                    <textarea name="description" class="form-control" rows="4"><%= product.description || '' %></textarea>
                </div>
                <div class="col-12">
                    <label class="form-label">Descrição curta</label>
                    <textarea name="short_description" class="form-control" rows="2"><%= product.short_description || '' %></textarea>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Inspiração</label>
                    <input name="inspiration" class="form-control" value="<%= product.inspiration || '' %>" placeholder="ex: Dior Sauvage" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Imagem destaque (URL)</label>
                    <input name="featured_image" class="form-control" value="<%= product.featured_image || '' %>" placeholder="https://..." />
                </div>

                <div class="col-12">
                    <label class="form-label">Imagens (JSON array ou lista separada por vírgula/linha)</label>
                    <textarea name="images" class="form-control" rows="2" placeholder='["url1","url2"] ou url1, url2'><%= product.images ? JSON.stringify(product.images) : '' %></textarea>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Tags (JSON array ou lista)</label>
                    <textarea name="tags" class="form-control" rows="2" placeholder='["doce","amadeirado"] ou doce, amadeirado'><%= product.tags ? JSON.stringify(product.tags) : '' %></textarea>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Ocasiões (JSON array ou lista)</label>
                    <textarea name="occasion" class="form-control" rows="2" placeholder='["noite","formal"] ou noite, formal'><%= product.occasion ? JSON.stringify(product.occasion) : '' %></textarea>
                </div>

                <div class="col-12">
                    <label class="form-label">Notas olfativas (JSON)</label>
                    <textarea name="notes" class="form-control" rows="3" placeholder='{"top":["bergamota"],"middle":["jasmim"],"base":["âmbar"]}'><%= product.notes ? JSON.stringify(product.notes) : '' %></textarea>
                </div>

                <div class="col-12 d-flex justify-content-end gap-2 mt-2">
                    <button type="submit" class="btn btn-primary"><%= action === 'edit' ? 'Salvar alterações' : 'Criar produto' %></button>
                </div>
            </div>
        </div>
    </form>
</div>

<%- include('../../partials/footer') %>
