<%- include('../../partials/header') %>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0">Pedidos</h1>
            <div class="text-muted small">Acompanhe status e entregas</div>
        </div>
        <a href="/admin" class="btn btn-outline-secondary">Voltar</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Cliente</th>
                            <th>Status</th>
                            <th>Pagamento</th>
                            <th class="text-end">Total</th>
                            <th class="text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (!orders || orders.length === 0) { %>
                            <tr>
                                <td colspan="6" class="text-muted">Nenhum pedido encontrado.</td>
                            </tr>
                        <% } else { %>
                            <% orders.forEach(o => { %>
                                <tr>
                                    <td><%= o.order_number %></td>
                                    <td><%= o.user ? o.user.name : '-' %></td>
                                    <td><span class="badge bg-secondary"><%= o.status %></span></td>
                                    <td><span class="badge bg-light text-dark"><%= o.payment_status %></span></td>
                                    <td class="text-end">R$ <%= Number(o.total_amount || 0).toFixed(2) %></td>
                                    <td class="text-end"><a class="btn btn-sm btn-primary" href="/admin/orders/<%= o.id %>">Detalhes</a></td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<%- include('../../partials/footer') %>
