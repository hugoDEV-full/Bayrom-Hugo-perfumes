<%- include('../partials/header') %>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Admin</h1>
        <div class="d-flex gap-2">
            <a href="/admin/products" class="btn btn-primary">Produtos</a>
            <a href="/admin/orders" class="btn btn-outline-primary">Pedidos</a>
            <a href="/admin/users" class="btn btn-outline-primary">Usuários</a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">Pedidos</div>
                    <div class="fs-4 fw-bold"><%= stats?.totalOrders ?? 0 %></div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">Receita (pago)</div>
                    <div class="fs-4 fw-bold">R$ <%= Number(stats?.totalRevenue || 0).toFixed(2) %></div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">Clientes</div>
                    <div class="fs-4 fw-bold"><%= stats?.totalUsers ?? 0 %></div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">Produtos ativos</div>
                    <div class="fs-4 fw-bold"><%= stats?.totalProducts ?? 0 %></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="h5 mb-0">Pedidos recentes</h2>
                        <a href="/admin/orders" class="btn btn-sm btn-outline-secondary">Ver todos</a>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Cliente</th>
                                    <th>Status</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (!recentOrders || recentOrders.length === 0) { %>
                                    <tr>
                                        <td colspan="4" class="text-muted">Nenhum pedido ainda.</td>
                                    </tr>
                                <% } else { %>
                                    <% recentOrders.forEach(o => { %>
                                        <tr>
                                            <td><a href="/admin/orders/<%= o.id %>"><%= o.order_number %></a></td>
                                            <td><%= o.user ? o.user.name : '-' %></td>
                                            <td><span class="badge bg-secondary"><%= o.status %></span></td>
                                            <td class="text-end">R$ <%= Number(o.total_amount || 0).toFixed(2) %></td>
                                        </tr>
                                    <% }) %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="h5 mb-0">Top produtos</h2>
                        <a href="/admin/products" class="btn btn-sm btn-outline-secondary">Gerenciar</a>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Produto</th>
                                    <th class="text-end">Vendas</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (!topProducts || topProducts.length === 0) { %>
                                    <tr>
                                        <td colspan="2" class="text-muted">Sem dados.</td>
                                    </tr>
                                <% } else { %>
                                    <% topProducts.forEach(p => { %>
                                        <tr>
                                            <td><%= p.name %></td>
                                            <td class="text-end"><%= p.sales_count ?? 0 %></td>
                                        </tr>
                                    <% }) %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <h2 class="h5">Atalhos</h2>
                    <div class="d-grid gap-2">
                        <a class="btn btn-outline-primary" href="/admin/products/new">Criar produto</a>
                        <a class="btn btn-outline-secondary" href="/admin/categories">Categorias</a>
                        <a class="btn btn-outline-secondary" href="/admin/settings">Configurações</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
