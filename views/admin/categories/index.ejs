<%- include('../../partials/header') %>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0">Categorias</h1>
            <div class="text-muted small">Organização do catálogo</div>
        </div>
        <a href="/admin" class="btn btn-outline-secondary">Voltar</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nome</th>
                            <th>Slug</th>
                            <th>Ativa</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (!categories || categories.length === 0) { %>
                            <tr><td colspan="4" class="text-muted">Nenhuma categoria.</td></tr>
                        <% } else { %>
                            <% categories.forEach(c => { %>
                                <tr>
                                    <td><%= c.id %></td>
                                    <td><%= c.name %></td>
                                    <td><%= c.slug %></td>
                                    <td><%= c.is_active ? 'sim' : 'não' %></td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<%- include('../../partials/footer') %>
