    <!-- Contact Form Script -->
    <script>
        document.getElementById('contactForm')?.addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const formData = new FormData(this);
            const data = Object.fromEntries(formData);
            
            // Show loading
            const submitBtn = this.querySelector('button[type="submit"]');
            const originalText = submitBtn.innerHTML;
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Enviando...';
            submitBtn.disabled = true;
            
            try {
                const response = await fetch('/contato', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(data)
                });
                
                if (response.ok) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Mensagem Enviada!',
                        text: 'Recebemos sua mensagem e responderemos em breve.',
                        timer: 4000,
                        showConfirmButton: false
                    });
                    
                    this.reset();
                    
                    // Redirect to WhatsApp after 2 seconds
                    setTimeout(() => {
                        window.open('https://wa.me/5561982976481?text=Olá! Acabei de enviar uma mensagem pelo site e gostaria de falar com alguém.', '_blank');
                    }, 2000);
                    
                } else {
                    throw new Error('Erro ao enviar mensagem');
                }
            } catch (error) {
                console.error('Contact form error:', error);
                Swal.fire({
                    icon: 'error',
                    title: 'Erro ao Enviar',
                    text: 'Ocorreu um erro. Por favor, tente novamente ou entre em contato diretamente pelo WhatsApp.',
                    confirmButtonText: 'Entendido',
                    confirmButtonColor: '#d4af37'
                });
            } finally {
                submitBtn.innerHTML = originalText;
                submitBtn.disabled = false;
            }
        });
        
        // Phone mask
        document.getElementById('phone')?.addEventListener('input', function(e) {
            let value = e.target.value.replace(/\D/g, '');
            if (value.length > 11) value = value.slice(0, 11);
            
            if (value.length > 10) {
                value = value.replace(/^(\d{2})(\d{5})(\d{4}).*/, '($1) $2-$3');
            } else if (value.length > 6) {
                value = value.replace(/^(\d{2})(\d{4})(\d{0,4}).*/, '($1) $2-$3');
            } else if (value.length > 2) {
                value = value.replace(/^(\d{2})(\d{0,5})/, '($1) $2');
            }
            
            e.target.value = value;
        });
    </script>
    
