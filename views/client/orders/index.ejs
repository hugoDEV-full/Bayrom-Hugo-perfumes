<%- include('../../partials/header') %>

<div class="container py-5">
    <h1 class="mb-4">Meus Pedidos</h1>

    <% if (!orders || orders.length === 0) { %>
        <div class="text-center py-5">
            <i class="fas fa-box-open fa-4x text-muted mb-3"></i>
            <h3>Você ainda não tem pedidos</h3>
            <p class="text-muted">Quando você finalizar uma compra, seus pedidos aparecerão aqui.</p>
            <a href="/products" class="btn btn-primary btn-lg">
                <i class="fas fa-shopping-bag"></i> Ver Produtos
            </a>
        </div>
    <% } else { %>
        <div class="row g-3">
            <% orders.forEach(order => { %>
                <div class="col-12">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                                <div>
                                    <div class="fw-bold">Pedido <%= order.order_number %></div>
                                    <small class="text-muted">
                                        <%= order.created_at ? new Date(order.created_at).toLocaleDateString('pt-BR') : '' %>
                                    </small>
                                </div>
                                <div class="text-end">
                                    <div class="fw-bold">R$ <%= Number(order.total_amount).toFixed(2).replace('.', ',') %></div>
                                    <small class="text-muted"><%= order.getStatusText ? order.getStatusText() : order.status %> | <%= order.getPaymentStatusText ? order.getPaymentStatusText() : order.payment_status %></small>
                                </div>
                            </div>

                            <div class="mt-3 d-flex flex-wrap gap-2">
                                <a href="/orders/<%= order.order_number %>" class="btn btn-outline-primary btn-sm">
                                    Ver detalhes
                                </a>
                                <a href="/orders/<%= order.order_number %>/invoice" class="btn btn-outline-secondary btn-sm">
                                    Baixar fatura
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</div>

<%- include('../../partials/footer') %>
