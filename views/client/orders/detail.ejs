<%- include('../../partials/header') %>

<div class="container py-5">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
        <div>
            <h1 class="mb-1">Pedido <%= order.order_number %></h1>
            <div class="text-muted">
                Status: <strong><%= order.getStatusText ? order.getStatusText() : order.status %></strong>
                | Pagamento: <strong><%= order.getPaymentStatusText ? order.getPaymentStatusText() : order.payment_status %></strong>
            </div>
        </div>
        <div class="text-end">
            <div class="fs-4 fw-bold">R$ <%= Number(order.total_amount).toFixed(2).replace('.', ',') %></div>
            <div class="text-muted"><%= order.created_at ? new Date(order.created_at).toLocaleString('pt-BR') : '' %></div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title mb-3">Itens</h5>

                    <% if (order.items && order.items.length > 0) { %>
                        <% order.items.forEach(item => { %>
                            <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                                <div>
                                    <div class="fw-bold"><%= item.product_name %></div>
                                    <small class="text-muted"><%= item.quantity %>x R$ <%= Number(item.unit_price).toFixed(2).replace('.', ',') %></small>
                                </div>
                                <div class="fw-bold">R$ <%= Number(item.total_price).toFixed(2).replace('.', ',') %></div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p class="text-muted mb-0">Nenhum item encontrado para este pedido.</p>
                    <% } %>

                    <div class="mt-3">
                        <a href="/orders/<%= order.order_number %>/invoice" class="btn btn-outline-secondary">
                            Baixar fatura
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="card-title">Resumo</h5>
                    <div class="d-flex justify-content-between mb-2"><span>Subtotal</span><span>R$ <%= Number(order.subtotal).toFixed(2).replace('.', ',') %></span></div>
                    <div class="d-flex justify-content-between mb-2"><span>Frete</span><span>R$ <%= Number(order.shipping_cost).toFixed(2).replace('.', ',') %></span></div>
                    <div class="d-flex justify-content-between mb-2"><span>Impostos</span><span>R$ <%= Number(order.tax_amount).toFixed(2).replace('.', ',') %></span></div>
                    <hr>
                    <div class="d-flex justify-content-between fw-bold"><span>Total</span><span>R$ <%= Number(order.total_amount).toFixed(2).replace('.', ',') %></span></div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Entrega</h5>
                    <% if (order.shippingAddress) { %>
                        <div class="small">
                            <div class="fw-bold"><%= order.shippingAddress.recipient_name %></div>
                            <div><%= order.shippingAddress.street %>, <%= order.shippingAddress.number %></div>
                            <% if (order.shippingAddress.complement) { %><div><%= order.shippingAddress.complement %></div><% } %>
                            <div><%= order.shippingAddress.neighborhood %> - <%= order.shippingAddress.city %>/<%= order.shippingAddress.state %></div>
                            <div>CEP: <%= order.shippingAddress.postal_code %></div>
                        </div>
                    <% } else { %>
                        <p class="text-muted mb-0">Endereço não disponível.</p>
                    <% } %>

                    <div class="mt-3">
                        <a href="/orders" class="btn btn-outline-primary w-100">Voltar</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../../partials/footer') %>
