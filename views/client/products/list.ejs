<%- include('../../partials/header') %>

<!-- Products Hero Section -->
<section class="py-5 bg-gradient-luxury">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8 mx-auto text-center">
                <div class="luxury-badge mb-4">
                    <i class="fas fa-spray-can"></i>
                    NOSSA COLEÇÃO
                </div>
                <h1 class="section-title-luxury">Perfumes Premium</h1>
                <p class="section-subtitle-luxury">Descubra fragrâncias excepcionais inspiradas nas melhores casas do mundo</p>
            </div>
        </div>
    </div>
</section>

<!-- Products Section -->
<section class="py-5">
    <div class="container">
        <div class="row">
            <!-- Filters Sidebar -->
            <div class="col-lg-3 mb-4">
                <div class="card luxury-card">
                    <div class="card-header bg-luxury-dark text-white">
                        <h6 class="mb-0"><i class="fas fa-filter me-2"></i>Filtros</h6>
                    </div>
                    <div class="card-body">
                        <!-- Categorias -->
                        <div class="mb-4">
                            <h6 class="fw-bold">Categorias</h6>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="category" id="cat-all" 
                                       value="" <%= !filters.category ? 'checked' : '' %> onchange="filterProducts()">
                                <label class="form-check-label" for="cat-all">
                                    Todas
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="category" id="cat-masculino" 
                                       value="masculino" <%= filters.category === 'masculino' ? 'checked' : '' %> onchange="filterProducts()">
                                <label class="form-check-label" for="cat-masculino">
                                    Masculino
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="category" id="cat-feminino" 
                                       value="feminino" <%= filters.category === 'feminino' ? 'checked' : '' %> onchange="filterProducts()">
                                <label class="form-check-label" for="cat-feminino">
                                    Feminino
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="category" id="cat-unisex" 
                                       value="unisex" <%= filters.category === 'unisex' ? 'checked' : '' %> onchange="filterProducts()">
                                <label class="form-check-label" for="cat-unisex">
                                    Unisex
                                </label>
                            </div>
                        </div>

                        <!-- Faixa de Preço -->
                        <div class="mb-4">
                            <h6 class="fw-bold">Faixa de Preço</h6>
                            <div class="row g-2">
                                <div class="col-6">
                                    <input type="number" class="form-control form-control-sm" 
                                           placeholder="Min" id="price_min" value="<%= filters.price_min || '' %>"
                                           onchange="filterProducts()">
                                </div>
                                <div class="col-6">
                                    <input type="number" class="form-control form-control-sm" 
                                           placeholder="Max" id="price_max" value="<%= filters.price_max || '' %>"
                                           onchange="filterProducts()">
                                </div>
                            </div>
                        </div>

                        <!-- Marcas -->
                        <div class="mb-4">
                            <h6 class="fw-bold">Marcas</h6>
                            <select class="form-select form-select-sm" id="brand" onchange="filterProducts()">
                                <option value="">Todas</option>
                                <% brands.forEach(brand => { %>
                                    <option value="<%= brand %>" <%= filters.brand === brand ? 'selected' : '' %>>
                                        <%= brand %>
                                    </option>
                                <% }); %>
                            </select>
                        </div>

                        <!-- Ordenação -->
                        <div class="mb-4">
                            <h6 class="fw-bold">Ordenar por</h6>
                            <select class="form-select form-select-sm" id="sort" onchange="filterProducts()">
                                <option value="created_at" <%= filters.sort === 'created_at' ? 'selected' : '' %>>
                                    Mais Novos
                                </option>
                                <option value="name" <%= filters.sort === 'name' ? 'selected' : '' %>>
                                    Nome
                                </option>
                                <option value="sale_price" <%= filters.sort === 'sale_price' ? 'selected' : '' %>>
                                    Menor Preço
                                </option>
                                <option value="rating_average" <%= filters.sort === 'rating_average' ? 'selected' : '' %>>
                                    Melhor Avaliação
                                </option>
                            </select>
                        </div>

                        <button class="btn btn-luxury btn-outline-luxury w-100" onclick="clearFilters()">
                            <i class="fas fa-times me-2"></i>Limpar Filtros
                        </button>
                    </div>
                </div>
            </div>

            <!-- Products Grid -->
            <div class="col-lg-9">
                <!-- Search Bar -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="input-group">
                            <input type="text" class="form-control" placeholder="Buscar perfumes..." 
                                   id="searchInput" value="<%= filters.search || '' %>">
                            <button class="btn btn-luxury" onclick="filterProducts()">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                    </div>
                    <div class="col-md-6 text-end">
                        <span class="text-muted">
                            <%= pagination.totalItems %> produto(s) encontrados
                        </span>
                    </div>
                </div>

                <!-- Products Grid -->
                <div class="row g-4" id="productsGrid">
                    <% if (products && products.length > 0) { %>
                        <% products.forEach(product => { %>
                            <div class="col-md-6 col-lg-4">
                                <div class="card h-100 luxury-card product-card">
                                    <% if (product.featured_image) { %>
                                        <img src="<%= product.featured_image %>" class="card-img-top product-image" 
                                             alt="<%= product.name %>">
                                    <% } else { %>
                                        <div class="card-img-top product-placeholder d-flex align-items-center justify-content-center">
                                            <i class="fas fa-spray-can fa-3x text-muted"></i>
                                        </div>
                                    <% } %>
                                    
                                    <div class="card-body d-flex flex-column">
                                        <div class="mb-2">
                                            <small class="text-muted"><%= product.brand %></small>
                                        </div>
                                        
                                        <h5 class="card-title"><%= product.name %></h5>
                                        
                                        <% if (product.inspiration) { %>
                                            <p class="card-text text-muted small">
                                                Inspirado em <%= product.inspiration %>
                                            </p>
                                        <% } %>
                                        
                                        <div class="mb-3">
                                            <% if (product.averageRating > 0) { %>
                                                <div class="rating">
                                                    <% for(let i = 1; i <= 5; i++) { %>
                                                        <% if (i <= Math.round(product.averageRating)) { %>
                                                            <i class="fas fa-star text-warning"></i>
                                                        <% } else { %>
                                                            <i class="far fa-star text-warning"></i>
                                                        <% } %>
                                                    <% } %>
                                                    <small class="text-muted">(<%= product.averageRating %>)</small>
                                                </div>
                                            <% } else { %>
                                                <small class="text-muted">Sem avaliação</small>
                                            <% } %>
                                        </div>
                                        
                                        <div class="mt-auto">
                                            <div class="d-flex justify-content-between align-items-center mb-3">
                                                <div>
                                                    <% if (product.sale_price && product.sale_price < product.price) { %>
                                                        <span class="text-decoration-line-through text-muted small">
                                                            R$ <%= product.price.toFixed(2) %>
                                                        </span>
                                                        <h5 class="text-success mb-0">R$ <%= product.sale_price.toFixed(2) %></h5>
                                                    <% } else { %>
                                                        <h5 class="mb-0">R$ <%= (product.sale_price || product.price).toFixed(2) %></h5>
                                                    <% } %>
                                                </div>
                                            </div>
                                            
                                            <div class="d-grid gap-2">
                                                <a href="/products/<%= product.id %>" class="btn btn-luxury">
                                                    Ver Detalhes
                                                </a>
                                                <button class="btn btn-outline-luxury" onclick="addToCart(<%= product.id %>)">
                                                    <i class="fas fa-shopping-cart me-2"></i>Adicionar
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="col-12">
                            <div class="text-center py-5">
                                <i class="fas fa-search fa-3x text-muted mb-3"></i>
                                <h4>Nenhum produto encontrado</h4>
                                <p class="text-muted">Tente ajustar os filtros ou buscar por outro termo</p>
                            </div>
                        </div>
                    <% } %>
                </div>

                <!-- Pagination -->
                <% if (pagination.totalPages > 1) { %>
                    <nav aria-label="Paginação de produtos" class="mt-5">
                        <ul class="pagination justify-content-center">
                            <% if (pagination.hasPrevPage) { %>
                                <li class="page-item">
                                    <a class="page-link" href="#" onclick="changePage(<%= pagination.currentPage - 1 %>)">
                                        <i class="fas fa-chevron-left"></i>
                                    </a>
                                </li>
                            <% } %>
                            
                            <% for(let i = 1; i <= pagination.totalPages; i++) { %>
                                <% if (i === pagination.currentPage) { %>
                                    <li class="page-item active">
                                        <span class="page-link"><%= i %></span>
                                    </li>
                                <% } else if (Math.abs(i - pagination.currentPage) <= 2 || i === 1 || i === pagination.totalPages) { %>
                                    <li class="page-item">
                                        <a class="page-link" href="#" onclick="changePage(<%= i %>)"><%= i %></a>
                                    </li>
                                <% } else if (Math.abs(i - pagination.currentPage) === 3) { %>
                                    <li class="page-item disabled">
                                        <span class="page-link">...</span>
                                    </li>
                                <% } %>
                            <% } %>
                            
                            <% if (pagination.hasNextPage) { %>
                                <li class="page-item">
                                    <a class="page-link" href="#" onclick="changePage(<%= pagination.currentPage + 1 %>)">
                                        <i class="fas fa-chevron-right"></i>
                                    </a>
                                </li>
                            <% } %>
                        </ul>
                    </nav>
                <% } %>
            </div>
        </div>
    </div>
</section>

<%- include('../../partials/footer') %>

<script>
function filterProducts() {
    const params = new URLSearchParams();
    
    const category = document.querySelector('input[name="category"]:checked')?.value;
    const priceMin = document.getElementById('price_min').value;
    const priceMax = document.getElementById('price_max').value;
    const brand = document.getElementById('brand').value;
    const sort = document.getElementById('sort').value;
    const search = document.getElementById('searchInput').value;
    
    if (category) params.append('category', category);
    if (priceMin) params.append('price_min', priceMin);
    if (priceMax) params.append('price_max', priceMax);
    if (brand) params.append('brand', brand);
    if (sort) params.append('sort', sort);
    if (search) params.append('search', search);
    
    window.location.href = '/products?' + params.toString();
}

function clearFilters() {
    window.location.href = '/products';
}

function changePage(page) {
    const params = new URLSearchParams(window.location.search);
    params.set('page', page);
    window.location.href = '/products?' + params.toString();
}

function addToCart(productId) {
    // Implementar lógica do carrinho
    fetch('/cart/add', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({
            product_id: productId,
            quantity: 1
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // Mostrar mensagem de sucesso
            const button = event.target;
            const originalText = button.innerHTML;
            button.innerHTML = '<i class="fas fa-check me-2"></i>Adicionado!';
            button.classList.add('btn-success');
            
            setTimeout(() => {
                button.innerHTML = originalText;
                button.classList.remove('btn-success');
            }, 2000);
        } else {
            alert('Erro ao adicionar ao carrinho');
        }
    })
    .catch(error => {
        console.error('Erro:', error);
        alert('Erro ao adicionar ao carrinho');
    });
}
</script>

