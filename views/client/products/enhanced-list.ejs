    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Sistema de Filtros Avançados
        class ProductFilter {
            constructor() {
                this.filters = {
                    category: 'all',
                    family: null,
                    price: null,
                    brand: null
                };
                this.init();
            }

            init() {
                this.setupFilterChips();
                this.setupViewToggle();
                this.setupSort();
                this.setupSearch();
                this.setupQuickActions();
            }

            setupFilterChips() {
                // Filtros de categoria
                document.querySelectorAll('[data-filter]').forEach(chip => {
                    chip.addEventListener('click', (e) => {
                        document.querySelectorAll('[data-filter]').forEach(c => c.classList.remove('active'));
                        e.target.classList.add('active');
                        this.filters.category = e.target.dataset.filter;
                        this.applyFilters();
                    });
                });

                // Filtros de família olfativa
                document.querySelectorAll('[data-family]').forEach(chip => {
                    chip.addEventListener('click', (e) => {
                        e.target.classList.toggle('active');
                        this.updateFamilyFilter();
                        this.applyFilters();
                    });
                });

                // Filtros de preço
                document.querySelectorAll('[data-price]').forEach(chip => {
                    chip.addEventListener('click', (e) => {
                        document.querySelectorAll('[data-price]').forEach(c => c.classList.remove('active'));
                        e.target.classList.add('active');
                        this.filters.price = e.target.dataset.price;
                        this.applyFilters();
                    });
                });

                // Filtros de marca
                document.querySelectorAll('[data-brand]').forEach(chip => {
                    chip.addEventListener('click', (e) => {
                        e.target.classList.toggle('active');
                        this.updateBrandFilter();
                        this.applyFilters();
                    });
                });
            }

            updateFamilyFilter() {
                const activeFamilies = Array.from(document.querySelectorAll('[data-family].active'))
                    .map(chip => chip.dataset.family);
                this.filters.family = activeFamilies.length > 0 ? activeFamilies : null;
            }

            updateBrandFilter() {
                const activeBrands = Array.from(document.querySelectorAll('[data-brand].active'))
                    .map(chip => chip.dataset.brand);
                this.filters.brand = activeBrands.length > 0 ? activeBrands : null;
            }

            applyFilters() {
                const products = document.querySelectorAll('.product-card-enhanced');
                let visibleCount = 0;

                products.forEach(product => {
                    let show = true;

                    // Filtro de categoria
                    if (this.filters.category !== 'all') {
                        if (product.dataset.category !== this.filters.category) {
                            show = false;
                        }
                    }

                    // Filtro de família olfativa
                    if (this.filters.family && !this.filters.family.includes(product.dataset.family)) {
                        show = false;
                    }

                    // Filtro de preço
                    if (this.filters.price) {
                        const price = parseInt(product.dataset.price);
                        const [min, max] = this.filters.price.split('-').map(p => p === '+' ? Infinity : parseInt(p));
                        if (price < min || price > max) {
                            show = false;
                        }
                    }

                    // Filtro de marca
                    if (this.filters.brand && !this.filters.brand.includes(product.dataset.brand)) {
                        show = false;
                    }

                    product.style.display = show ? 'block' : 'none';
                    if (show) visibleCount++;
                });

                // Atualizar contador
                document.querySelector('.results-info span').innerHTML = 
                    `Mostrando <strong>${visibleCount}</strong> de <strong>100</strong> produtos`;
            }

            setupViewToggle() {
                const viewBtns = document.querySelectorAll('.view-btn');
                const container = document.getElementById('productsContainer');

                viewBtns.forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        viewBtns.forEach(b => b.classList.remove('active'));
                        e.target.classList.add('active');

                        const view = e.target.dataset.view;
                        if (view === 'list') {
                            container.className = 'products-list';
                        } else {
                            container.className = 'products-grid';
                        }
                    });
                });
            }

            setupSort() {
                const sortDropdown = document.querySelector('.sort-dropdown');
                sortDropdown.addEventListener('change', (e) => {
                    this.sortProducts(e.target.value);
                });
            }

            sortProducts(sortBy) {
                const container = document.getElementById('productsContainer');
                const products = Array.from(container.children);

                products.sort((a, b) => {
                    switch (sortBy) {
                        case 'price-low':
                            return parseInt(a.dataset.price) - parseInt(b.dataset.price);
                        case 'price-high':
                            return parseInt(b.dataset.price) - parseInt(a.dataset.price);
                        case 'name':
                            return a.querySelector('.product-name').textContent.localeCompare(
                                b.querySelector('.product-name').textContent
                            );
                        case 'rating':
                            const ratingA = parseFloat(a.querySelector('.rating-count').textContent.match(/\d+/)[0]);
                            const ratingB = parseFloat(b.querySelector('.rating-count').textContent.match(/\d+/)[0]);
                            return ratingB - ratingA;
                        default:
                            return 0;
                    }
                });

                products.forEach(product => container.appendChild(product));
            }

            setupSearch() {
                const searchInput = document.querySelector('.search-bar input');
                searchInput.addEventListener('input', (e) => {
                    const query = e.target.value.toLowerCase();
                    const products = document.querySelectorAll('.product-card-enhanced');

                    products.forEach(product => {
                        const name = product.querySelector('.product-name').textContent.toLowerCase();
                        const brand = product.querySelector('.product-brand').textContent.toLowerCase();
                        const description = product.querySelector('.product-description').textContent.toLowerCase();

                        const match = name.includes(query) || brand.includes(query) || description.includes(query);
                        product.style.display = match ? 'block' : 'none';
                    });
                });
            }

            setupQuickActions() {
                // Botões de quick action
                document.querySelectorAll('.quick-action-btn').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        e.stopPropagation();
                        const action = e.target.closest('button').title;
                        this.handleQuickAction(action);
                    });
                });

                // Botão de adicionar ao carrinho
                document.querySelectorAll('.btn-add-to-cart').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        e.stopPropagation();
                        this.addToCart(e.target);
                    });
                });

                // Botão de wishlist
                document.querySelectorAll('.btn-wishlist').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        e.stopPropagation();
                        this.toggleWishlist(e.target);
                    });
                });
            }

            handleQuickAction(action) {
                switch (action) {
                    case 'Visualização Rápida':
                        this.showQuickView();
                        break;
                    case 'Comparar':
                        this.addToCompare();
                        break;
                    case 'Teste Virtual':
                        this.startVirtualTry();
                        break;
                }
            }

            showQuickView() {
                // Implementar modal de visualização rápida
                console.log('Mostrando visualização rápida...');
            }

            addToCompare() {
                // Implementar sistema de comparação
                console.log('Adicionando à comparação...');
            }

            startVirtualTry() {
                // Implementar teste virtual
                console.log('Iniciando teste virtual...');
            }

            addToCart(button) {
                // Simular adição ao carrinho
                const originalText = button.innerHTML;
                button.innerHTML = '<i class="fas fa-check me-2"></i>Adicionado!';
                button.style.background = '#27ae60';
                
                setTimeout(() => {
                    button.innerHTML = originalText;
                    button.style.background = '';
                }, 2000);

                // Atualizar contador do carrinho
                const cartCount = document.querySelector('.fa-shopping-cart').parentElement;
                const currentCount = parseInt(cartCount.textContent.match(/\d+/)[0]);
                cartCount.innerHTML = `<i class="fas fa-shopping-cart"></i> Carrinho (${currentCount + 1})`;
            }

            toggleWishlist(button) {
                button.classList.toggle('active');
                const icon = button.querySelector('i');
                
                if (button.classList.contains('active')) {
                    icon.classList.remove('far');
                    icon.classList.add('fas');
                } else {
                    icon.classList.remove('fas');
                    icon.classList.add('far');
                }
            }
        }

        // Inicializar sistema quando o DOM estiver pronto
        document.addEventListener('DOMContentLoaded', () => {
            new ProductFilter();

            // Simular carregamento
            const loadingBar = document.getElementById('loadingBar');
            loadingBar.classList.add('active');
            
            setTimeout(() => {
                loadingBar.classList.remove('active');
            }, 1000);
        });

        // Efeitos de hover avançados
        document.addEventListener('DOMContentLoaded', () => {
            const productCards = document.querySelectorAll('.product-card-enhanced');
            
            productCards.forEach(card => {
                card.addEventListener('mouseenter', () => {
                    card.style.zIndex = '10';
                });
                
                card.addEventListener('mouseleave', () => {
                    card.style.zIndex = '';
                });
            });
        });
    </script>
    
    <script src="/js/material-system.js"></script>
    <script>
        // Inicializar sistema de materiais quando a página carregar
        document.addEventListener('DOMContentLoaded', () => {
            // Inicializar o sistema de materiais
            if (window.materialSystem) {
                window.materialSystem.updateMaterials();
            }
            
            // Adicionar efeitos de hover avançados com materiais
            const productCards = document.querySelectorAll('.product-card-enhanced');
            
            productCards.forEach(card => {
                card.addEventListener('mouseenter', () => {
                    card.style.zIndex = '10';
                    // Adicionar brilho extra baseado no material
                    const materialClass = card.classList.value.match(/material-(\w+)/);
                    if (materialClass) {
                        card.classList.add('material-glow');
                    }
                });
                
                card.addEventListener('mouseleave', () => {
                    card.style.zIndex = '';
                    card.classList.remove('material-glow');
                });
                
                // Adicionar efeito de clique com partículas
                card.addEventListener('click', function(e) {
                    if (!e.target.closest('button')) {
                        if (window.materialSystem) {
                            window.materialSystem.createMaterialBurst(this);
                        }
                    }
                });
            });
        });
    </script>
