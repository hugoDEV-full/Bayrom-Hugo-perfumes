<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/material-system.js"></script>
<script>
    // Criar partículas de materiais no hero
    function createMaterialParticles() {
        const heroParticles = document.querySelector('.hero-particles');
        if (!heroParticles) return;

        const materials = ['gold', 'diamond', 'ruby', 'emerald', 'sapphire', 'amethyst', 'platinum', 'silver'];
        
        for (let i = 0; i < 50; i++) {
            const particle = document.createElement('div');
            const material = materials[Math.floor(Math.random() * materials.length)];
            particle.className = `particle ${material}-particle`;
            particle.style.left = Math.random() * 100 + '%';
            particle.style.animationDelay = Math.random() * 15 + 's';
            particle.style.animationDuration = (15 + Math.random() * 10) + 's';
            heroParticles.appendChild(particle);
        }
    }

    // Inicializar partículas quando a página carregar
    document.addEventListener('DOMContentLoaded', () => {
        createMaterialParticles();
        
        // Adicionar efeito de brilho aos cards de materiais
        const materialCards = document.querySelectorAll('.material-card');
        materialCards.forEach(card => {
            card.addEventListener('mouseenter', function() {
                this.style.transform = 'translateY(-15px) scale(1.02)';
            });
            
            card.addEventListener('mouseleave', function() {
                this.style.transform = 'translateY(0) scale(1)';
            });
        });

        // Adicionar efeito de clique nos cards de perfumes
        const perfumeCards = document.querySelectorAll('.perfume-material-card');
        perfumeCards.forEach(card => {
            card.addEventListener('click', function() {
                // Criar efeito de explosão de partículas
                const burst = document.createElement('div');
                burst.style.cssText = `
                    position: absolute;
                    top: 50%;
                    left: 50%;
                    transform: translate(-50%, -50%);
                    pointer-events: none;
                    z-index: 1000;
                `;
                
                for (let i = 0; i < 12; i++) {
                    const particle = document.createElement('div');
                    const angle = (i * 30) * Math.PI / 180;
                    const distance = 30 + Math.random() * 50;
                    
                    particle.style.cssText = `
                        position: absolute;
                        width: 6px;
                        height: 6px;
                        border-radius: 50%;
                        background: linear-gradient(135deg, #FFD700, #FFFFFF);
                        animation: burst 0.8s ease-out forwards;
                        transform: translate(${Math.cos(angle) * distance}px, ${Math.sin(angle) * distance}px);
                    `;
                    
                    burst.appendChild(particle);
                }
                
                this.appendChild(burst);
                setTimeout(() => burst.remove(), 800);
            });
        });
    });

    // Adicionar CSS para animação de burst
    const style = document.createElement('style');
    style.textContent = `
        @keyframes burst {
            0% {
                transform: translate(0, 0) scale(1);
                opacity: 1;
            }
            100% {
                transform: translate(var(--tx), var(--ty)) scale(0);
                opacity: 0;
            }
        }
    `;
    document.head.appendChild(style);
</script>
