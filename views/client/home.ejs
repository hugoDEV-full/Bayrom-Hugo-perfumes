        .hero-luxury {
            background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 50%, #1a1a1a 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            position: relative;
            overflow: hidden;
        }

        .hero-particles {
            position: absolute;
            width: 100%;
            height: 100%;
            overflow: hidden;
        }

        .particle {
            position: absolute;
            width: 4px;
            height: 4px;
            border-radius: 50%;
            opacity: 0.6;
            animation: float 15s infinite;
        }

        .gold-particle { background: linear-gradient(135deg, #FFD700, #D4AF37); }
        .diamond-particle { background: linear-gradient(135deg, #FFFFFF, #B9F2FF); }
        .ruby-particle { background: linear-gradient(135deg, #E0115F, #9B111E); }
        .emerald-particle { background: linear-gradient(135deg, #50C878, #006B3C); }
        .sapphire-particle { background: linear-gradient(135deg, #0F52BA, #002366); }
        .amethyst-particle { background: linear-gradient(135deg, #9966CC, #6A0DAD); }
        .platinum-particle { background: linear-gradient(135deg, #E5E4E2, #C0C0C0); }
        .silver-particle { background: linear-gradient(135deg, #C0C0C0, #BFC1C2); }
        .copper-particle { background: linear-gradient(135deg, #B87333, #8B4513); }

        @keyframes float {
            0%, 100% { transform: translateY(0) translateX(0); opacity: 0; }
            10% { opacity: 0.6; }
            90% { opacity: 0.6; }
            100% { transform: translateY(-100vh) translateX(100px); opacity: 0; }
        }

        .brand-title {
            font-family: 'Playfair Display', serif;
            font-size: 4rem;
            font-weight: 900;
            background: linear-gradient(135deg, #FFD700, #FFFFFF, #E0115F, #0F52BA, #50C878);
            background-size: 200% auto;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: shine 3s linear infinite;
        }

        @keyframes shine {
            to { background-position: 200% center; }
        }

        .material-showcase {
            padding: 80px 0;
            background: linear-gradient(135deg, #f8f9fa, #ffffff);
        }

        .material-card {
            border-radius: 20px;
            padding: 2px;
            margin-bottom: 30px;
            transition: all 0.4s ease;
            cursor: pointer;
        }

        .material-card:hover {
            transform: translateY(-10px);
        }

        .material-card-content {
            background: white;
            border-radius: 18px;
            padding: 30px;
            text-align: center;
        }

        .material-icon-large {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 2rem;
            color: white;
        }

        .perfume-material-card {
            position: relative;
            border-radius: 20px;
            overflow: hidden;
            margin-bottom: 30px;
            transition: all 0.4s ease;
        }

        .perfume-material-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
        }

        .material-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            pointer-events: none;
            z-index: 1;
        }

        .material-shimmer {
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(
                45deg,
                transparent 30%,
                rgba(255, 255, 255, 0.3) 50%,
                transparent 70%
            );
            animation: shimmer 3s infinite;
        }
    </style>
