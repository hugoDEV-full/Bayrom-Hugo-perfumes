                            <button class="add-to-wishlist" data-product-id="<%= product.id %>">
                                <i class="far fa-heart"></i>
                            </button>
                            <button class="add-to-cart" data-product-id="<%= product.id %>">
                                <i class="fas fa-shopping-cart"></i>
                            </button>
                        </div>
                    </div>
                    
                    <div class="card-body">
                        <div class="product-brand"><%= product.brand %></div>
                        <h5 class="product-name"><%= product.name %></h5>
                        
                        <div class="product-price">
                            <% if (product.sale_price && product.sale_price < product.regular_price) { %>
                                <span class="price-current">R$ <%= product.sale_price.toFixed(2).replace('.', ',') %></span>
                                <span class="price-original">R$ <%= product.regular_price.toFixed(2).replace('.', ',') %></span>
                            <% } else { %>
                                <span class="price-current">R$ <%= product.regular_price.toFixed(2).replace('.', ',') %></span>
                            <% } %>
                        </div>
                        
                        <div class="mt-3">
                            <a href="/products/<%= product.slug %>" class="btn btn-outline-primary btn-sm w-100">
                                Ver Detalhes
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<!-- Sale Products -->
<section class="py-5 bg-danger bg-gradient">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 text-white">Ofertas Especiais</h2>
            <p class="text-white-50">Aproveite nossos descontos por tempo limitado</p>
        </div>
        
        <div class="row g-4">
            <% saleProducts.slice(0, 4).forEach(product => { %>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="product-card">
                    <div class="product-image">
                        <img src="<%= product.featured_image || '/images/product-placeholder.jpg' %>" 
                             alt="<%= product.name %>" 
                             loading="lazy">
                        
                        <span class="badge-sale">
                            -<%= Math.round(((product.regular_price - product.sale_price) / product.regular_price) * 100) %>%
                        </span>
                        
                        <div class="product-actions">
                            <button class="add-to-wishlist" data-product-id="<%= product.id %>">
                                <i class="far fa-heart"></i>
                            </button>
                            <button class="add-to-cart" data-product-id="<%= product.id %>">
                                <i class="fas fa-shopping-cart"></i>
                            </button>
                        </div>
                    </div>
                    
                    <div class="card-body">
                        <div class="product-brand"><%= product.brand %></div>
                        <h5 class="product-name"><%= product.name %></h5>
                        
                        <div class="product-price">
                            <span class="price-current">R$ <%= product.sale_price.toFixed(2).replace('.', ',') %></span>
                            <span class="price-original">R$ <%= product.regular_price.toFixed(2).replace('.', ',') %></span>
                        </div>
                        
                        <div class="mt-3">
                            <a href="/products/<%= product.slug %>" class="btn btn-primary btn-sm w-100">
                                Ver Detalhes
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<!-- Newsletter Section -->
<section class="py-5 bg-dark text-white">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h3>Receba Ofertas Exclusivas</h3>
                <p class="text-white-50">Cadastre-se e ganhe 10% de desconto na primeira compra!</p>
            </div>
            <div class="col-lg-6">
                <form class="d-flex gap-2" id="heroNewsletterForm">
                    <input type="email" class="form-control" placeholder="Seu melhor email" required>
                    <button type="submit" class="btn btn-warning">Cadastrar</button>
                </form>
            </div>
        </div>
    </div>
</section>

<!-- Trust Badges -->
<section class="py-4 bg-light border-top">
    <div class="container">
        <div class="row align-items-center text-center">
            <div class="col-md-3 col-6 mb-3 mb-md-0">
                <i class="fas fa-credit-card fa-2x text-primary mb-2"></i>
                <div class="small">Pagamento Seguro</div>
            </div>
            <div class="col-md-3 col-6 mb-3 mb-md-0">
                <i class="fas fa-box fa-2x text-success mb-2"></i>
                <div class="small">Embalagem Discreta</div>
            </div>
            <div class="col-md-3 col-6 mb-3 mb-md-0">
                <i class="fas fa-headset fa-2x text-warning mb-2"></i>
                <div class="small">Suporte Especializado</div>
            </div>
            <div class="col-md-3 col-6">
                <i class="fas fa-star fa-2x text-danger mb-2"></i>
                <div class="small">Satisfação Garantida</div>
            </div>
        </div>
    </div>
</section>

<%- include('../partials/footer') %>
