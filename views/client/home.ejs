<%- include('../partials/header') %>

<!-- Hero Section Luxuoso -->
<section class="hero-luxury">
    <div class="hero-overlay"></div>
    <div class="container h-100">
        <div class="row h-100 align-items-center">
            <div class="col-lg-7">
                <div class="hero-content-luxury">
                    <div class="luxury-badge mb-3">
                        <span class="badge-text">BAYROM & HUGO PARFUMS</span>
                    </div>
                    <h1 class="hero-title-luxury">
                        <span class="title-line">A Arte da</span>
                        <span class="title-line accent">Perfumaria</span>
                        <span class="title-line">de Nicho</span>
                    </h1>
                    <p class="hero-description-luxury">
                        Descubra fragrâncias excepcionais inspiradas nas mais prestigiadas casas de perfumes. 
                        Cada nota é uma jornada sensorial única, criada para quem busca o extraordinário.
                    </p>
                    <div class="hero-actions-luxury">
                        <a href="#inspiracoes" class="btn-luxury btn-primary-luxury">
                            <span>Explorar Coleção</span>
                            <i class="fas fa-crown"></i>
                        </a>
                        <a href="#sobre" class="btn-luxury btn-outline-luxury">
                            <span>Nossa Filosofia</span>
                            <i class="fas fa-compass"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="hero-scroll-indicator">
        <i class="fas fa-chevron-down"></i>
    </div>
</section>

