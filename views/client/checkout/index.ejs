<%- include('../../partials/header') %>

<div class="container py-5">
    <div class="row">
        <div class="col-lg-8">
            <h1 class="mb-4">Finalizar Compra</h1>

            <div class="card shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="card-title mb-3">Endereço de Entrega</h5>

                    <form method="POST" action="/checkout/place-order" id="checkoutForm">
                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <label class="form-label">Nome do Destinatário *</label>
                                <input type="text" class="form-control" name="recipient_name" required
                                    value="<%= defaultShippingAddress ? defaultShippingAddress.recipient_name : '' %>">
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">CEP *</label>
                                <input type="text" class="form-control" name="postal_code" placeholder="00000-000" required
                                    value="<%= defaultShippingAddress ? defaultShippingAddress.postal_code : '' %>">
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <label class="form-label">Rua *</label>
                                <input type="text" class="form-control" name="street" required
                                    value="<%= defaultShippingAddress ? defaultShippingAddress.street : '' %>">
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Número *</label>
                                <input type="text" class="form-control" name="number" required
                                    value="<%= defaultShippingAddress ? defaultShippingAddress.number : '' %>">
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Complemento</label>
                                <input type="text" class="form-control" name="complement"
                                    value="<%= defaultShippingAddress ? (defaultShippingAddress.complement || '') : '' %>">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Bairro *</label>
                                <input type="text" class="form-control" name="neighborhood" required
                                    value="<%= defaultShippingAddress ? defaultShippingAddress.neighborhood : '' %>">
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Cidade *</label>
                                <input type="text" class="form-control" name="city" required
                                    value="<%= defaultShippingAddress ? defaultShippingAddress.city : '' %>">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Estado (UF) *</label>
                                <input type="text" class="form-control" name="state" placeholder="SP" maxlength="2" required
                                    value="<%= defaultShippingAddress ? defaultShippingAddress.state : '' %>">
                            </div>
                        </div>

                        <div class="form-check mb-4">
                            <input class="form-check-input" type="checkbox" name="save_as_default" id="saveDefault" <%= defaultShippingAddress ? '' : 'checked' %>>
                            <label class="form-check-label" for="saveDefault">
                                Salvar como endereço padrão
                            </label>
                        </div>

                        <h5 class="mb-3">Pagamento</h5>
                        <div class="mb-3">
                            <label class="form-label">Método *</label>
                            <select class="form-select" name="payment_method" required>
                                <option value="pix">PIX</option>
                                <option value="boleto">Boleto</option>
                                <option value="credit_card">Cartão de Crédito</option>
                                <option value="debit_card">Cartão de Débito</option>
                            </select>
                            <small class="text-muted">Pagamento real via gateway pode ser integrado depois. Por enquanto o pedido fica registrado como pagamento pendente.</small>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Observações</label>
                            <textarea class="form-control" name="notes" rows="3" placeholder="Ex: deixar na portaria..."></textarea>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-check"></i> Confirmar Pedido
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h5 class="card-title mb-3">Itens do Carrinho</h5>
                    <% cartItems.forEach(item => { %>
                        <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                            <div>
                                <div class="fw-bold"><%= item.product.name %></div>
                                <small class="text-muted"><%= item.quantity %>x R$ <%= Number(item.unit_price).toFixed(2).replace('.', ',') %></small>
                            </div>
                            <div class="fw-bold">R$ <%= Number(item.total_price).toFixed(2).replace('.', ',') %></div>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h5 class="card-title">Resumo</h5>

                    <div class="d-flex justify-content-between mb-2">
                        <span>Subtotal</span>
                        <span>R$ <%= totals.subtotal.toFixed(2).replace('.', ',') %></span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Frete</span>
                        <span><%= totals.shipping === 0 ? 'Grátis' : ('R$ ' + totals.shipping.toFixed(2).replace('.', ',')) %></span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between fw-bold fs-5">
                        <span>Total</span>
                        <span>R$ <%= totals.total.toFixed(2).replace('.', ',') %></span>
                    </div>

                    <div class="mt-3">
                        <small class="text-muted">
                            <i class="fas fa-shield-alt"></i>
                            Pedido registrado e confirmado no sistema.
                        </small>
                    </div>

                    <div class="mt-4">
                        <a href="/cart" class="btn btn-outline-secondary w-100">
                            Voltar ao carrinho
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../../partials/footer') %>
