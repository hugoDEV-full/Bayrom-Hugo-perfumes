<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Bayrom & Hugo Parfums</title>
    <meta name="description" content="<%= description %>">
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;900&family=Montserrat:wght@300;400;500;600;700&family=Cormorant+Garamond:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/luxury.css">
</head>
<body>
    <!-- Header -->
    <%- include('../partials/header') %>
    
    <!-- Hero Section -->
    <section class="py-5 bg-gradient-luxury">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-8 mx-auto text-center">
                    <div class="luxury-badge mb-4">
                        <i class="fas fa-credit-card"></i>
                        FORMAS DE PAGAMENTO
                    </div>
                    <h1 class="section-title-luxury">
                        Pague Como Preferir
                    </h1>
                    <p class="section-subtitle-luxury">
                        Múltiplas opções seguras e convenientes para sua tranquilidade.
                    </p>
                </div>
            </div>
        </div>
    </section>
    
    <!-- Payment Methods -->
    <section class="py-5 bg-light-luxury">
        <div class="container">
            <div class="row">
                <div class="col-lg-10 mx-auto">
                    <div class="payment-content">
                        <!-- Payment Methods Grid -->
                        <div class="payment-methods">
                            <div class="payment-method-card">
                                <div class="payment-icon">
                                    <i class="fas fa-credit-card"></i>
                                </div>
                                <h3>Cartão de Crédito</h3>
                                <div class="payment-badges">
                                    <span class="payment-badge visa">VISA</span>
                                    <span class="payment-badge master">MASTERCARD</span>
                                    <span class="payment-badge amex">AMEX</span>
                                    <span class="payment-badge elo">ELO</span>
                                    <span class="payment-badge hipercard">HIPERCARD</span>
                                </div>
                                <div class="payment-features">
                                    <div class="feature">
                                        <i class="fas fa-check-circle"></i>
                                        <span>Até 12x sem juros</span>
                                    </div>
                                    <div class="feature">
                                        <i class="fas fa-check-circle"></i>
                                        <span>Parcela mínima R$ 50,00</span>
                                    </div>
                                    <div class="feature">
                                        <i class="fas fa-check-circle"></i>
                                        <span>Processamento instantâneo</span>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="payment-method-card">
                                <div class="payment-icon">
                                    <i class="fas fa-barcode"></i>
                                </div>
                                <h3>Boleto Bancário</h3>
                                <div class="payment-image">
                                    <img src="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 200 100'><rect fill='%23f0f0f0' width='200' height='100'/><line x1='20' y1='30' x2='180' y2='30' stroke='%23333' stroke-width='2'/><line x1='20' y1='40' x2='180' y2='40' stroke='%23333' stroke-width='2'/><line x1='20' y1='50' x2='180' y2='50' stroke='%23333' stroke-width='2'/><line x1='20' y1='60' x2='180' y2='60' stroke='%23333' stroke-width='2'/><line x1='20' y1='70' x2='180' y2='70' stroke='%23333' stroke-width='2'/><text x='100' y='90' text-anchor='middle' font-family='monospace' font-size='8'>BOLETO</text></svg>" alt="Boleto">
                                </div>
                                <div class="payment-features">
                                    <div class="feature">
                                        <i class="fas fa-check-circle"></i>
                                        <span>5% de desconto</span>
                                    </div>
                                    <div class="feature">
                                        <i class="fas fa-check-circle"></i>
                                        <span>Pague em qualquer banco</span>
                                    </div>
                                    <div class="feature">
                                        <i class="fas fa-check-circle"></i>
                                        <span>Vencimento em 3 dias</span>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="payment-method-card">
                                <div class="payment-icon">
                                    <i class="fab fa-pix"></i>
                                </div>
                                <h3>Pix</h3>
                                <div class="payment-image">
                                    <img src="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect fill='%2300c853' width='100' height='100'/><path d='M50 20 L60 35 L80 35 L70 50 L80 65 L60 65 L50 80 L40 65 L20 65 L30 50 L20 35 L40 35 Z' fill='white'/><circle cx='50' cy='50' r='8' fill='%2300c853'/></svg>" alt="Pix">
                                </div>
                                <div class="payment-features">
                                    <div class="feature">
                                        <i class="fas fa-check-circle"></i>
                                        <span>5% de desconto</span>
                                    </div>
                                    <div class="feature">
                                        <i class="fas fa-check-circle"></i>
                                        <span>Transferência instantânea</span>
                                    </div>
                                    <div class="feature">
                                        <i class="fas fa-check-circle"></i>
                                        <span>Disponível 24/7</span>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="payment-method-card">
                                <div class="payment-icon">
                                    <i class="fab fa-paypal"></i>
                                </div>
                                <h3>PayPal</h3>
                                <div class="payment-badges">
                                    <span class="payment-badge paypal">PAYPAL</span>
                                </div>
                                <div class="payment-features">
                                    <div class="feature">
                                        <i class="fas fa-check-circle"></i>
                                        <span>Proteção comprador</span>
                                    </div>
                                    <div class="feature">
                                        <i class="fas fa-check-circle"></i>
                                        <span>Reconhecido mundialmente</span>
                                    </div>
                                    <div class="feature">
                                        <i class="fas fa-check-circle"></i>
                                        <span>Parcelado pelo PayPal</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Security Section -->
                        <div class="security-section">
                            <h3><i class="fas fa-shield-alt"></i> Segurança em Primeiro Lugar</h3>
                            <div class="security-features">
                                <div class="security-feature">
                                    <div class="security-icon">
                                        <i class="fas fa-lock"></i>
                                    </div>
                                    <h4>Criptografia SSL</h4>
                                    <p>Todas as transações são criptografadas com tecnologia SSL de 256 bits</p>
                                </div>
                                
                                <div class="security-feature">
                                    <div class="security-icon">
                                        <i class="fas fa-user-shield"></i>
                                    </div>
                                    <h4>Proteção de Dados</h4>
                                    <p>Seus dados são protegidos conforme a Lei Geral de Proteção de Dados</p>
                                </div>
                                
                                <div class="security-feature">
                                    <div class="security-icon">
                                        <i class="fas fa-shield-virus"></i>
                                    </div>
                                    <h4>Antifraude</h4>
                                    <p>Sistema avançado de detecção de fraudes em todas as transações</p>
                                </div>
                                
                                <div class="security-feature">
                                    <div class="security-icon">
                                        <i class="fas fa-certificate"></i>
                                    </div>
                                    <h4>Certificação</h4>
                                    <p>Gateways de pagamento certificados e regulamentados pelo Banco Central</p>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Installment Info -->
                        <div class="installment-section">
                            <h3><i class="fas fa-calculator"></i> Tabela de Parcelamento</h3>
                            <div class="installment-table">
                                <div class="table-header">
                                    <div class="header-cell">Valor da Compra</div>
                                    <div class="header-cell">Parcelas Sem Juros</div>
                                    <div class="header-cell">Valor da Parcela</div>
                                </div>
                                
                                <div class="table-row">
                                    <div class="cell">Até R$ 150,00</div>
                                    <div class="cell">2x</div>
                                    <div class="cell">50% do valor</div>
                                </div>
                                
                                <div class="table-row">
                                    <div class="cell">R$ 151,00 a R$ 300,00</div>
                                    <div class="cell">3x</div>
                                    <div class="cell">33,3% do valor</div>
                                </div>
                                
                                <div class="table-row">
                                    <div class="cell">R$ 301,00 a R$ 600,00</div>
                                    <div class="cell">6x</div>
                                    <div class="cell">16,6% do valor</div>
                                </div>
                                
                                <div class="table-row">
                                    <div class="cell">Acima de R$ 600,00</div>
                                    <div class="cell">12x</div>
                                    <div class="cell">8,3% do valor</div>
                                </div>
                            </div>
                            
                            <div class="installment-note">
                                <i class="fas fa-info-circle"></i>
                                <p>Parcela mínima de R$ 50,00. Para valores acima de R$ 1.000,00, 
                                consulte condições especiais de parcelamento.</p>
                            </div>
                        </div>
                        
                        <!-- Payment Process -->
                        <div class="process-section">
                            <h3><i class="fas fa-cogs"></i> Como Funciona o Pagamento</h3>
                            <div class="process-steps">
                                <div class="process-step">
                                    <div class="step-number">1</div>
                                    <div class="step-content">
                                        <h4>Escolha os Produtos</h4>
                                        <p>Adicione seus perfumes desejados ao carrinho de compras</p>
                                    </div>
                                </div>
                                
                                <div class="process-step">
                                    <div class="step-number">2</div>
                                    <div class="step-content">
                                        <h4>Finalize Compra</h4>
                                        <p>Confirme seus dados e escolha a forma de pagamento</p>
                                    </div>
                                </div>
                                
                                <div class="process-step">
                                    <div class="step-number">3</div>
                                    <div class="step-content">
                                        <h4>Pague com Segurança</h4>
                                        <p>Complete o pagamento em ambiente 100% seguro</p>
                                    </div>
                                </div>
                                
                                <div class="process-step">
                                    <div class="step-number">4</div>
                                    <div class="step-content">
                                        <h4>Receba Confirmação</h4>
                                        <p>Acompanhe seu pedido e receba suas fragrâncias</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- FAQ Section -->
                        <div class="faq-section">
                            <h3><i class="fas fa-question-circle"></i> Dúvidas Frequentes</h3>
                            <div class="accordion luxury-accordion" id="paymentFaqAccordion">
                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button" type="button" data-bs-toggle="collapse" 
                                                data-bs-target="#payfaq1" aria-expanded="true">
                                            <i class="fas fa-question-circle"></i>
                                            É seguro comprar com cartão no site?
                                        </button>
                                    </h2>
                                    <div id="payfaq1" class="accordion-collapse collapse show" 
                                         data-bs-parent="#paymentFaqAccordion">
                                        <div class="accordion-body">
                                            Sim! Utilizamos os mais altos padrões de segurança com criptografia SSL 
                                            e gateways de pagamento certificados. Seus dados são processados 
                                            diretamente pelas operadoras, sem serem armazenados em nossos servidores.
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" 
                                                data-bs-target="#payfaq2" aria-expanded="false">
                                            <i class="fas fa-question-circle"></i>
                                            Posso parcelar no boleto?
                                        </button>
                                    </h2>
                                    <div id="payfaq2" class="accordion-collapse collapse" 
                                         data-bs-parent="#paymentFaqAccordion">
                                        <div class="accordion-body">
                                            Não. O boleto deve ser pago à vista, mas você ganha 5% de desconto 
                                            sobre o valor total da compra. Para parcelamento, utilize cartão de crédito.
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" 
                                                data-bs-target="#payfaq3" aria-expanded="false">
                                            <i class="fas fa-question-circle"></i>
                                            Como funciona o desconto no Pix?
                                        </button>
                                    </h2>
                                    <div id="payfaq3" class="accordion-collapse collapse" 
                                         data-bs-parent="#paymentFaqAccordion">
                                        <div class="accordion-body">
                                            Ao escolher Pix, você recebe automaticamente 5% de desconto sobre 
                                            o valor total. O código Pix é gerado imediatamente e, após o pagamento, 
                                            seu pedido é confirmado em até 30 minutos.
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Contact CTA -->
                        <div class="contact-cta">
                            <div class="cta-card">
                                <h4><i class="fas fa-headset"></i> Precisa de Ajuda com o Pagamento?</h4>
                                <p>Nossa equipe financeira está disponível para ajudar você!</p>
                                <div class="contact-options">
                                    <div class="contact-option">
                                        <i class="fab fa-whatsapp"></i>
                                        <div>
                                            <strong>WhatsApp</strong>
                                            <span>(61) 98297-6481</span>
                                        </div>
                                    </div>
                                    <div class="contact-option">
                                        <i class="fas fa-envelope"></i>
                                        <div>
                                            <strong>Email</strong>
                                            <span>hugo.leonardo.jobs@gmail.com</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="cta-actions">
                                    <a href="https://wa.me/5561982976481" class="btn-luxury btn-success-luxury" target="_blank">
                                        <i class="fab fa-whatsapp"></i>
                                        WhatsApp Financeiro
                                    </a>
                                    <a href="/contato" class="btn-luxury btn-outline-luxury">
                                        <i class="fas fa-envelope"></i>
                                        Enviar Email
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- Footer -->
    <%- include('../partials/footer') %>
    
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
    <script src="/js/luxury.js"></script>
    
    <style>
        .payment-content {
            background: white;
            border-radius: 25px;
            padding: 50px;
            box-shadow: var(--shadow-soft);
        }
        
        .payment-methods {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
            margin-bottom: 60px;
        }
        
        .payment-method-card {
            background: linear-gradient(135deg, 
                rgba(255, 255, 255, 0.95), 
                rgba(248, 246, 255, 0.9));
            border: 2px solid rgba(212, 175, 55, 0.2);
            border-radius: 20px;
            padding: 40px 30px;
            text-align: center;
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
        }
        
        .payment-method-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: 
                radial-gradient(circle at 50% 50%, rgba(212, 175, 55, 0.05) 0%, transparent 70%);
            pointer-events: none;
        }
        
        .payment-method-card:hover {
            transform: translateY(-10px);
            box-shadow: var(--shadow-luxury);
            border-color: var(--luxury-gold);
        }
        
        .payment-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(45deg, var(--luxury-gold), #f4e4bc);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 2rem;
            color: var(--luxury-dark);
            box-shadow: 0 10px 30px rgba(212, 175, 55, 0.3);
        }
        
        .payment-method-card h3 {
            font-family: var(--font-primary);
            font-weight: 600;
            color: var(--luxury-dark);
            margin-bottom: 20px;
            position: relative;
            z-index: 2;
        }
        
        .payment-badges {
            display: flex;
            justify-content: center;
            gap: 8px;
            margin: 20px 0;
            flex-wrap: wrap;
        }
        
        .payment-badge {
            padding: 5px 12px;
            border-radius: 8px;
            font-size: 0.75rem;
            font-weight: 700;
            color: white;
            text-transform: uppercase;
        }
        
        .payment-badge.visa { background: #1a1f71; }
        .payment-badge.master { background: #eb001b; }
        .payment-badge.amex { background: #006fcf; }
        .payment-badge.elo { background: #0033a0; }
        .payment-badge.hipercard { background: #8b1538; }
        .payment-badge.paypal { background: #00457c; }
        
        .payment-image {
            margin: 20px 0;
            display: flex;
            justify-content: center;
        }
        
        .payment-image img {
            width: 120px;
            height: 60px;
            object-fit: contain;
            border-radius: 8px;
        }
        
        .payment-features {
            display: flex;
            flex-direction: column;
            gap: 12px;
            position: relative;
            z-index: 2;
        }
        
        .feature {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.9rem;
            color: var(--luxury-gray);
        }
        
        .feature i {
            color: var(--luxury-gold);
            font-size: 1rem;
        }
        
        .security-section {
            margin-bottom: 60px;
        }
        
        .security-section h3 {
            font-family: var(--font-primary);
            font-weight: 600;
            color: var(--luxury-dark);
            margin-bottom: 30px;
            text-align: center;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
        }
        
        .security-section h3 i {
            color: var(--luxury-gold);
        }
        
        .security-features {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 30px;
        }
        
        .security-feature {
            text-align: center;
            padding: 30px;
            background: linear-gradient(135deg, 
                rgba(212, 175, 55, 0.05), 
                rgba(233, 180, 160, 0.03));
            border-radius: 15px;
            border: 1px solid rgba(212, 175, 55, 0.1);
            transition: all 0.3s ease;
        }
        
        .security-feature:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-luxury);
            border-color: var(--luxury-gold);
        }
        
        .security-icon {
            width: 60px;
            height: 60px;
            background: linear-gradient(45deg, var(--luxury-gold), #f4e4bc);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 1.5rem;
            color: var(--luxury-dark);
        }
        
        .security-feature h4 {
            font-family: var(--font-secondary);
            font-weight: 600;
            color: var(--luxury-dark);
            margin-bottom: 10px;
        }
        
        .security-feature p {
            color: var(--luxury-gray);
            font-size: 0.9rem;
            line-height: 1.6;
        }
        
        .installment-section {
            margin-bottom: 60px;
        }
        
        .installment-section h3 {
            font-family: var(--font-primary);
            font-weight: 600;
            color: var(--luxury-dark);
            margin-bottom: 30px;
            text-align: center;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
        }
        
        .installment-section h3 i {
            color: var(--luxury-gold);
        }
        
        .installment-table {
            background: white;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: var(--shadow-soft);
            margin-bottom: 20px;
        }
        
        .table-header {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            background: linear-gradient(45deg, var(--luxury-gold), #f4e4bc);
            color: var(--luxury-dark);
            font-weight: 700;
            padding: 20px;
        }
        
        .table-row {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            padding: 20px;
            border-bottom: 1px solid var(--luxury-light-gray);
            transition: background 0.3s ease;
        }
        
        .table-row:hover {
            background: rgba(212, 175, 55, 0.05);
        }
        
        .table-row:last-child {
            border-bottom: none;
        }
        
        .installment-note {
            background: rgba(212, 175, 55, 0.05);
            border-left: 4px solid var(--luxury-gold);
            padding: 15px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .installment-note i {
            color: var(--luxury-gold);
            font-size: 1.2rem;
        }
        
        .process-section {
            margin-bottom: 60px;
        }
        
        .process-section h3 {
            font-family: var(--font-primary);
            font-weight: 600;
            color: var(--luxury-dark);
            margin-bottom: 30px;
            text-align: center;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
        }
        
        .process-section h3 i {
            color: var(--luxury-gold);
        }
        
        .process-steps {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 30px;
        }
        
        .process-step {
            text-align: center;
            position: relative;
        }
        
        .step-number {
            width: 60px;
            height: 60px;
            background: linear-gradient(45deg, var(--luxury-gold), #f4e4bc);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-family: var(--font-primary);
            font-weight: 700;
            font-size: 1.5rem;
            color: var(--luxury-dark);
            box-shadow: 0 8px 20px rgba(212, 175, 55, 0.3);
        }
        
        .step-content h4 {
            font-family: var(--font-secondary);
            font-weight: 600;
            color: var(--luxury-dark);
            margin-bottom: 10px;
        }
        
        .step-content p {
            color: var(--luxury-gray);
            font-size: 0.9rem;
            line-height: 1.6;
        }
        
        .faq-section {
