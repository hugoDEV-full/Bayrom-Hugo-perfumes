<%- include('../partials/header') %>

<div class="container py-5">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
        <div>
            <h1 class="mb-1">Meu Perfil</h1>
            <div class="text-muted">Gerencie sua conta e acompanhe seus pedidos</div>
        </div>
        <div class="d-flex gap-2">
            <a href="/orders" class="btn btn-outline-secondary">Meus pedidos</a>
            <a href="/auth/logout" class="btn btn-outline-danger">Sair</a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title mb-3">Dados da conta</h5>
                    <div class="mb-2"><strong>Nome:</strong> <%= user?.name || '' %></div>
                    <div class="mb-2"><strong>Email:</strong> <%= user?.email || '' %></div>
                    <div class="mb-0"><strong>Tipo:</strong> <%= user?.role || '' %></div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title mb-3">Atalhos</h5>
                    <div class="d-grid gap-2">
                        <a href="/products" class="btn btn-primary">Ver produtos</a>
                        <a href="/cart" class="btn btn-outline-primary">Ir para o carrinho</a>
                        <a href="/checkout" class="btn btn-outline-success">Finalizar compra</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
