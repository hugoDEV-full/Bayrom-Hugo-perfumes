    <script src="/js/material-system.js"></script>
    <script>
        // Criar partículas flutuantes
        function createFloatingParticles() {
            const container = document.getElementById('particlesContainer');
            const materials = [
                { color: 'linear-gradient(135deg, #FFD700, #D4AF37)', name: 'gold' },
                { color: 'linear-gradient(135deg, #FFFFFF, #B9F2FF)', name: 'diamond' },
                { color: 'linear-gradient(135deg, #E0115F, #9B111E)', name: 'ruby' },
                { color: 'linear-gradient(135deg, #50C878, #006B3C)', name: 'emerald' },
                { color: 'linear-gradient(135deg, #0F52BA, #002366)', name: 'sapphire' },
                { color: 'linear-gradient(135deg, #9966CC, #6A0DAD)', name: 'amethyst' },
                { color: 'linear-gradient(135deg, #E5E4E2, #C0C0C0)', name: 'platinum' },
                { color: 'linear-gradient(135deg, #E0BFB8, #D4A76A)', name: 'rose-gold' }
            ];
            
            for (let i = 0; i < 30; i++) {
                const particle = document.createElement('div');
                const material = materials[Math.floor(Math.random() * materials.length)];
                
                particle.className = `floating-particle ${material.name}-particle`;
                particle.style.background = material.color;
                particle.style.width = Math.random() * 8 + 4 + 'px';
                particle.style.height = particle.style.width;
                particle.style.left = Math.random() * 100 + '%';
                particle.style.animationDelay = Math.random() * 20 + 's';
                particle.style.animationDuration = (20 + Math.random() * 10) + 's';
                
                container.appendChild(particle);
            }
        }

        // Sistema de combinação de materiais
        class MaterialMixer {
            constructor() {
                this.selectedMaterials = [];
                this.maxSelection = 3;
                this.init();
            }

            init() {
                const options = document.querySelectorAll('.material-option');
                options.forEach(option => {
                    option.addEventListener('click', () => this.toggleMaterial(option));
                });
            }

            toggleMaterial(option) {
                const material = option.dataset.material;
                
                if (option.classList.contains('selected')) {
                    option.classList.remove('selected');
                    this.selectedMaterials = this.selectedMaterials.filter(m => m !== material);
                } else if (this.selectedMaterials.length < this.maxSelection) {
                    option.classList.add('selected');
                    this.selectedMaterials.push(material);
                } else {
                    // Mostrar mensagem de limite
                    this.showMessage('Você pode selecionar no máximo 3 materiais');
                    return;
                }
                
                this.updateMixResult();
            }

            updateMixResult() {
                const resultDiv = document.getElementById('mixResult');
                
                if (this.selectedMaterials.length === 0) {
                    resultDiv.innerHTML = `
                        <h3 class="mix-result-title">Selecione os Materiais</h3>
                        <p class="mix-result-description">
                            Escolha até 3 materiais para criar sua combinação única
                        </p>
                    `;
                } else {
                    const combination = this.getCombinationInfo();
                    resultDiv.innerHTML = `
                        <h3 class="mix-result-title">${combination.title}</h3>
                        <p class="mix-result-description">${combination.description}</p>
                        <div class="mt-3">
                            <span class="property-tag">${combination.personality}</span>
                            <span class="property-tag">${combination.style}</span>
                            <span class="property-tag">${combination.occasion}</span>
                        </div>
                    `;
                }
            }

            getCombinationInfo() {
                const combinations = {
                    'gold,diamond,ruby': {
                        title: 'Luxo Real',
                        description: 'Uma combinação majestosa que representa poder, riqueza e paixão. Ideal para quem não tem medo de ser o centro das atenções.',
                        personality: 'Destemido',
                        style: 'Sofisticado',
                        occasion: 'Eventos Especiais'
                    },
                    'diamond,sapphire,emerald': {
                        title: 'Elegância Clássica',
                        description: 'A união da pureza com a sabedoria e natureza. Perfeita para quem valoriza tradição e refinamento.',
                        personality: 'Clássico',
                        style: 'Elegante',
                        occasion: 'Uso Diário'
                    },
                    'ruby,amethyst,rose-gold': {
                        title: 'Mistério e Paixão',
                        description: 'Uma mistura enigmática que combina intensidade com mistério e romance. Para almas livres e criativas.',
                        personality: 'Misterioso',
                        style: 'Romântico',
                        occasion: 'Noites Especiais'
                    },
                    'gold,platinum,onyx': {
                        title: 'Poder Absoluto',
                        description: 'A combinação máxima de força e prestígio. Indicada para líderes e pessoas que comandam respeito.',
                        personality: 'Líder',
                        style: 'Poderoso',
                        occasion: 'Reuniões Importantes'
                    }
                };

                const key = this.selectedMaterials.sort().join(',');
                return combinations[key] || {
                    title: 'Sua Combinação Única',
                    description: `Uma seleção especial de ${this.selectedMaterials.length} materiais que cria uma fragrância exclusivamente sua.`,
                    personality: 'Único',
                    style: 'Personalizado',
                    occasion: 'Qualquer Momento'
                };
            }

            showMessage(message) {
                // Criar toast de notificação
                const toast = document.createElement('div');
                toast.className = 'position-fixed top-50 start-50 translate-middle bg-dark text-white p-3 rounded-3';
                toast.style.zIndex = '9999';
                toast.textContent = message;
                
                document.body.appendChild(toast);
                
                setTimeout(() => {
                    toast.remove();
                }, 3000);
            }
        }

        // Animar contadores
        function animateCounters() {
            const counters = document.querySelectorAll('.stat-number');
            
            counters.forEach(counter => {
                const target = parseInt(counter.dataset.target);
                const duration = 2000;
                const step = target / (duration / 16);
                let current = 0;
                
                const updateCounter = () => {
                    current += step;
                    if (current < target) {
                        counter.textContent = Math.floor(current);
                        requestAnimationFrame(updateCounter);
                    } else {
                        counter.textContent = target;
                    }
                };
                
                updateCounter();
            });
        }

        // Inicializar quando a página carregar
        document.addEventListener('DOMContentLoaded', () => {
            createFloatingParticles();
            new MaterialMixer();
            
            // Iniciar animação dos contadores quando visível
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        animateCounters();
                        observer.disconnect();
                    }
                });
            });
            
            const statsSection = document.querySelector('.stats-section');
            if (statsSection) {
                observer.observe(statsSection);
            }
            
            // Adicionar efeitos de hover
            const cards = document.querySelectorAll('.material-showcase-card');
            cards.forEach(card => {
                card.addEventListener('mouseenter', function() {
                    this.style.transform = 'translateY(-15px) scale(1.03)';
                });
                
                card.addEventListener('mouseleave', function() {
                    this.style.transform = 'translateY(0) scale(1)';
                });
            });
        });
    </script>
</body>
</html>
