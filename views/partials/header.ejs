<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Bayrom & Hugo Parfums' %></title>
    <meta name="description" content="<%= typeof description !== 'undefined' ? description : 'Loja virtual de perfumes premium - Bayrom & Hugo Parfums' %>">
    
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico">
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;900&family=Montserrat:wght@300;400;500;600;700&family=Cormorant+Garamond:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/luxury.css">
    <link rel="stylesheet" href="/css/luxury-materials.css">
    <link rel="stylesheet" href="/css/material-extensions.css">
    
    <!-- Structured Data -->
    <% if (typeof product !== 'undefined') { %>
    <script type="application/ld+json">
    {
        "@context": "https://schema.org/",
        "@type": "Product",
        "name": "<%= product.name %>",
        "image": "<%= product.featured_image || '/images/product-placeholder.jpg' %>",
        "description": "<%= product.short_description || product.description %>",
        "brand": {
            "@type": "Brand",
            "name": "<%= product.brand %>"
        },
        "offers": {
            "@type": "Offer",
            "priceCurrency": "BRL",
            "price": "<%= product.getDisplayPrice() %>",
            "availability": "<%= product.isInStock() ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock' %>"
        }
    }
    </script>
    <% } %>
</head>
<body>
    <!-- Luxury Top Bar -->
    <div class="luxury-top-bar">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <div class="luxury-contact">
                        <span><i class="fas fa-phone-alt"></i> (11) 94220-0022</span>
                        <span><i class="fas fa-envelope"></i> contato@bayromhugoperfumes.com.br</span>
                    </div>
                </div>
                <div class="col-lg-6 text-end">
                    <div class="luxury-benefits">
                        <span><i class="fas fa-crown"></i> Clube VIP</span>
                        <span><i class="fas fa-shield-alt"></i> Garantia Bayrom</span>
                        <span><i class="fas fa-truck"></i> Entrega Expressa</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Luxury Navigation -->
    <nav class="luxury-navbar">
        <div class="container">
            <div class="luxury-nav-wrapper">
                <!-- Logo -->
                <div class="luxury-brand">
                    <a href="/" class="brand-link">
                        <div class="brand-icon">
                            <i class="fas fa-crown"></i>
                        </div>
                        <div class="brand-text">
                            <div class="brand-name">BAYROM & HUGO</div>
                            <div class="brand-tagline">PARFUMS</div>
                        </div>
                    </a>
                </div>
                
                <!-- Mobile Menu Toggle -->
                <button class="luxury-mobile-toggle" onclick="toggleLuxuryMenu()">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
                
                <!-- Main Navigation -->
                <div class="luxury-nav-menu" id="luxuryNavMenu">
                    <ul class="luxury-nav-list">
                        <li class="luxury-nav-item">
                            <a href="/" class="luxury-nav-link">Início</a>
                        </li>
                        <li class="luxury-nav-item">
                            <a href="/encyclopedia" class="luxury-nav-link">
                                <i class="fas fa-book-open"></i> Enciclopédia
                            </a>
                        </li>
                        <li class="luxury-nav-item">
                            <a href="/materiais-preciosos" class="luxury-nav-link">
                                <i class="fas fa-gem"></i> Materiais Preciosos
                            </a>
                        </li>
                        <li class="luxury-nav-item dropdown-luxury">
                            <a href="#" class="luxury-nav-link dropdown-toggle-luxury" onclick="toggleDropdown('masculino')">
                                Masculino <i class="fas fa-chevron-down"></i>
                            </a>
                            <div class="luxury-dropdown" id="masculino-dropdown">
                                <div class="luxury-dropdown-content">
                                    <div class="dropdown-section">
                                        <h6>Categorias</h6>
                                        <a href="/products?category=masculino">Todos Masculinos</a>
                                        <a href="/products?category=masculino&fragrance_family=citrico">Cítricos Frescos</a>
                                        <a href="/products?category=masculino&fragrance_family=amadeirado">Amadeirados Elegantes</a>
                                        <a href="/products?category=masculino&fragrance_family=oriental">Orientais Poderosos</a>
                                        <a href="/products?category=masculino&fragrance_family=aquatico">Aquáticos Modernos</a>
                                    </div>
                                    <div class="dropdown-featured">
                                        <h6>Destaques</h6>
                                        <div class="featured-item">
                                            <i class="fas fa-star"></i>
                                            <span>Inspirado em Aventus</span>
                                        </div>
                                        <div class="featured-item">
                                            <i class="fas fa-star"></i>
                                            <span>Inspirado em Sauvage</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </li>
                        <li class="luxury-nav-item dropdown-luxury">
                            <a href="#" class="luxury-nav-link dropdown-toggle-luxury" onclick="toggleDropdown('feminino')">
                                Feminino <i class="fas fa-chevron-down"></i>
                            </a>
                            <div class="luxury-dropdown" id="feminino-dropdown">
                                <div class="luxury-dropdown-content">
                                    <div class="dropdown-section">
                                        <h6>Categorias</h6>
                                        <a href="/products?category=feminino">Todos Femininos</a>
                                        <a href="/products?category=feminino&fragrance_family=floral">Florais Românticos</a>
                                        <a href="/products?category=feminino&fragrance_family=frutal">Frutais Vibrantes</a>
                                        <a href="/products?category=feminino&fragrance_family=doce">Doces Sedutores</a>
                                        <a href="/products?category=feminino&fragrance_family=oriental">Orientais Misteriosos</a>
                                    </div>
                                    <div class="dropdown-featured">
                                        <h6>Destaques</h6>
                                        <div class="featured-item">
                                            <i class="fas fa-star"></i>
                                            <span>Inspirado em Chanel No. 5</span>
                                        </div>
                                        <div class="featured-item">
                                            <i class="fas fa-star"></i>
                                            <span>Inspirado em Black Opium</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </li>
                        <li class="luxury-nav-item">
                            <a href="/products?category=unisex" class="luxury-nav-link">Unisex</a>
                        </li>
                        <li class="luxury-nav-item">
                            <a href="/sobre-nos" class="luxury-nav-link">Nossa História</a>
                        </li>
                        <li class="luxury-nav-item">
                            <a href="/contato" class="luxury-nav-link">Contato VIP</a>
                        </li>
                    </ul>
                </div>
                
                <!-- Right Actions -->
                <div class="luxury-actions">
                    <!-- Search -->
                    <div class="luxury-search">
                        <button class="search-toggle" onclick="toggleSearch()">
                            <i class="fas fa-search"></i>
                        </button>
                        <div class="search-dropdown" id="luxurySearch">
                            <form onsubmit="performLuxurySearch(event)">
                                <input type="text" class="luxury-search-input" placeholder="Buscar fragrâncias exclusivas..." required>
                                <button type="submit" class="luxury-search-btn">
                                    <i class="fas fa-search"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                    
                    <!-- WhatsApp -->
                    <a href="https://wa.me/5561982976481?text=Olá! Tenho interesse em seus produtos." 
                       class="luxury-action-link whatsapp-link" target="_blank">
                        <i class="fab fa-whatsapp"></i>
                        <span>WhatsApp</span>
                    </a>
                    
                    <!-- User Account -->
                    <% if (user) { %>
                        <div class="luxury-user dropdown-luxury">
                            <button class="luxury-user-btn" onclick="toggleDropdown('user')">
                                <i class="fas fa-user"></i>
                                <span class="user-name"><%= user.name.split(' ')[0] %></span>
                                <i class="fas fa-chevron-down"></i>
                            </button>
                            <div class="luxury-dropdown user-dropdown" id="user-dropdown">
                                <div class="luxury-dropdown-content">
                                    <a href="/account/profile"><i class="fas fa-user"></i> Meu Perfil</a>
                                    <a href="/account/orders"><i class="fas fa-box"></i> Meus Pedidos</a>
                                    <a href="/account/wishlist"><i class="fas fa-heart"></i> Favoritos</a>
                                    <a href="/account/addresses"><i class="fas fa-map-marker-alt"></i> Endereços</a>
                                    <% if (user.role === 'admin') { %>
                                        <a href="/admin"><i class="fas fa-cog"></i> Painel Admin</a>
                                    <% } %>
                                    <hr class="luxury-divider">
                                    <a href="/logout"><i class="fas fa-sign-out-alt"></i> Sair</a>
                                </div>
                            </div>
                        </div>
                    <% } else { %>
                        <a href="/login" class="luxury-action-link">
                            <i class="fas fa-user"></i>
                            <span>Entrar</span>
                        </a>
                    <% } %>
                    
                    <!-- Wishlist -->
                    <a href="/account/wishlist" class="luxury-action-link">
                        <i class="fas fa-heart"></i>
                        <span class="action-count" id="wishlistCount">0</span>
                    </a>
                    
                    <!-- Cart -->
                    <a href="/cart" class="luxury-action-link cart-link">
                        <i class="fas fa-shopping-bag"></i>
                        <span class="action-count" id="cartCount">0</span>
                    </a>
                </div>
            </div>
        </div>
    </nav>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/admin"><i class="fas fa-cog"></i> Painel Admin</a></li>
                                <% } %>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/auth/logout"><i class="fas fa-sign-out-alt"></i> Sair</a></li>
                            </ul>
                        </div>
                    <% } else { %>
                        <a href="/auth/login" class="btn btn-link text-dark">
                            <i class="fas fa-user"></i>
                            <span class="d-none d-md-inline">Entrar</span>
                        </a>
                    <% } %>
                    
                    <!-- Cart -->
                    <a href="/cart" class="btn btn-link text-dark position-relative">
                        <i class="fas fa-shopping-cart"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                            <%= cart.reduce((sum, item) => sum + item.quantity, 0) %>
                        </span>
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Flash Messages -->
    <% if (typeof success_msg !== 'undefined' && success_msg.length > 0) { %>
        <div class="alert alert-success alert-dismissible fade show m-0" role="alert">
            <%= success_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>
    
    <% if (typeof error_msg !== 'undefined' && error_msg.length > 0) { %>
        <div class="alert alert-danger alert-dismissible fade show m-0" role="alert">
            <%= error_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <!-- Main Content -->

    <!-- Luxury JavaScript -->
    <script src="/js/luxury.js"></script>
