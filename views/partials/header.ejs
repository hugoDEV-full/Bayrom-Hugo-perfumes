<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Bayrom & Hugo Parfums' %></title>
    <meta name="description" content="<%= typeof description !== 'undefined' ? description : 'Loja virtual de perfumes premium - Bayrom & Hugo Parfums' %>">
    
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico">
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
    
    <!-- Structured Data -->
    <% if (typeof product !== 'undefined') { %>
    <script type="application/ld+json">
    {
        "@context": "https://schema.org/",
        "@type": "Product",
        "name": "<%= product.name %>",
        "image": "<%= product.featured_image || '/images/product-placeholder.jpg' %>",
        "description": "<%= product.short_description || product.description %>",
        "brand": {
            "@type": "Brand",
            "name": "<%= product.brand %>"
        },
        "offers": {
            "@type": "Offer",
            "priceCurrency": "BRL",
            "price": "<%= product.getDisplayPrice() %>",
            "availability": "<%= product.isInStock() ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock' %>"
        }
    }
    </script>
    <% } %>
</head>
<body>
    <!-- Top Bar -->
    <div class="top-bar bg-dark text-white py-2">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <div class="d-flex align-items-center gap-3">
                        <small><i class="fas fa-phone"></i> (11) 94220-0022</small>
                        <small><i class="fas fa-envelope"></i> contato@bayromhugoperfumes.com.br</small>
                    </div>
                </div>
                <div class="col-md-6 text-end">
                    <div class="d-flex align-items-center justify-content-end gap-3">
                        <small><i class="fas fa-truck"></i> Frete grátis acima de R$ 250</small>
                        <small><i class="fas fa-shield-alt"></i> Compra segura</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Navigation -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand" href="/">
                <img src="/images/logo.png" alt="Bayrom & Hugo Parfums" height="40">
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Início</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            Masculino
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/products?category=masculino">Todos Masculinos</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/products?category=masculino&fragrance_family=citrico">Cítricos</a></li>
                            <li><a class="dropdown-item" href="/products?category=masculino&fragrance_family=amadeirado">Amadeirados</a></li>
                            <li><a class="dropdown-item" href="/products?category=masculino&fragrance_family=oriental">Orientais</a></li>
                            <li><a class="dropdown-item" href="/products?category=masculino&fragrance_family=aquatico">Aquáticos</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            Feminino
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/products?category=feminino">Todos Femininos</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/products?category=feminino&fragrance_family=floral">Florais</a></li>
                            <li><a class="dropdown-item" href="/products?category=feminino&fragrance_family=frutal">Frutais</a></li>
                            <li><a class="dropdown-item" href="/products?category=feminino&fragrance_family=doce">Doces</a></li>
                            <li><a class="dropdown-item" href="/products?category=feminino&fragrance_family=oriental">Orientais</a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/products?category=unisex">Unisex</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/sobre-nos">Sobre Nós</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/contato">Contato</a>
                    </li>
                </ul>
                
                <!-- Search and User Actions -->
                <div class="d-flex align-items-center gap-3">
                    <!-- Search -->
                    <div class="search-box">
                        <input type="text" class="form-control" placeholder="Buscar perfumes..." id="searchInput">
                        <button class="btn btn-link text-dark" onclick="performSearch()">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                    
                    <!-- User Account -->
                    <% if (user) { %>
                        <div class="dropdown">
                            <button class="btn btn-link text-dark dropdown-toggle" data-bs-toggle="dropdown">
                                <i class="fas fa-user"></i>
                                <span class="d-none d-md-inline"><%= user.name.split(' ')[0] %></span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="/account/profile"><i class="fas fa-user"></i> Meu Perfil</a></li>
                                <li><a class="dropdown-item" href="/account/orders"><i class="fas fa-box"></i> Meus Pedidos</a></li>
                                <li><a class="dropdown-item" href="/account/wishlist"><i class="fas fa-heart"></i> Favoritos</a></li>
                                <li><a class="dropdown-item" href="/account/addresses"><i class="fas fa-map-marker-alt"></i> Endereços</a></li>
                                <% if (user.role === 'admin') { %>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/admin"><i class="fas fa-cog"></i> Painel Admin</a></li>
                                <% } %>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/auth/logout"><i class="fas fa-sign-out-alt"></i> Sair</a></li>
                            </ul>
                        </div>
                    <% } else { %>
                        <a href="/auth/login" class="btn btn-link text-dark">
                            <i class="fas fa-user"></i>
                            <span class="d-none d-md-inline">Entrar</span>
                        </a>
                    <% } %>
                    
                    <!-- Cart -->
                    <a href="/cart" class="btn btn-link text-dark position-relative">
                        <i class="fas fa-shopping-cart"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                            <%= cart.reduce((sum, item) => sum + item.quantity, 0) %>
                        </span>
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Flash Messages -->
    <% if (typeof success_msg !== 'undefined' && success_msg.length > 0) { %>
        <div class="alert alert-success alert-dismissible fade show m-0" role="alert">
            <%= success_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>
    
    <% if (typeof error_msg !== 'undefined' && error_msg.length > 0) { %>
        <div class="alert alert-danger alert-dismissible fade show m-0" role="alert">
            <%= error_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <!-- Main Content -->
